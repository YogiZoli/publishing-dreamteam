ENVIRONMENT=development
BASE_URL=http://localhost:8000
DATABASE_URL=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SESSION_SECRET=
FERNET_KEY=
CRM_PROVIDER=ghl
CRM_API_TOKEN=
CRM_LOCATION_ID=
CRM_FREE_USER_TAG=dreamteam-free-user
FLAG_FREE_TIER=true
FLAG_PAID_TIER=false
# Accurate chapters via YouTube auto-captions + async backfill (Session 7 C0).
FLAG_TRANSCRIPT_PROXY=false
# Egress for the caption fetch: none | local | proxy
#   local = direct fetch on a residential IP (dev, $0)
#   proxy = route via a residential HTTP proxy (required on Railway prod)
TRANSCRIPT_EGRESS=none
# Generic HTTP proxy URL used when TRANSCRIPT_EGRESS=proxy (Railway env only)
TRANSCRIPT_PROXY_URL=
